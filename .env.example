# ─── Database Provider ──────────────────────────────────────────────────────
# Controls which Prisma schema is used.
# "mysql"       → Local development  → prisma/schema.mysql.prisma
# "sqlserver"   → Production hosting → prisma/schema.sqlserver.prisma
DB_PROVIDER="mysql"

# ─── Database Connection ─────────────────────────────────────────────────────

# MySQL (local development):
# DATABASE_URL="mysql://root:your_password@localhost:3306/suki_crm"

# MS SQL Server (production/hosting):
# DATABASE_URL="sqlserver://<server>:1433;database=suki_marketing_crm;user=<user>;password=<password>;encrypt=true;trustServerCertificate=true;"

DATABASE_URL="mysql://root:your_password@localhost:3306/suki_crm"

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="your_jwt_secret_here"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret_minimum_32_characters_long"

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Auth Domain & Token Settings ────────────────────────────────────────────
ALLOWED_DOMAIN=sukisoftware.com
RESET_TOKEN_EXPIRY_MINUTES=15
ACTIVATION_TOKEN_EXPIRY_HOURS=24
AUTH_JWT_EXPIRY=30m

# ─── SMTP Email ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sukisoftware.com

# ─── Customer Portal ─────────────────────────────────────────────────────────
CUSTOMER_PORTAL_URL=http://localhost:3000/customer/portal
