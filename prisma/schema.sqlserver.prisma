// ─── PRODUCTION SCHEMA (MS SQL Server) ───────────────────────────────────────
// Used when DB_PROVIDER=sqlserver (or NODE_ENV=production)
// Connection string format:
//   sqlserver://<server>:<port>;database=<db>;user=<user>;password=<pass>;encrypt=true;trustServerCertificate=true;

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Admin
  MarketingLead
  MarketingExecutive
  Customer
}

enum CustomerStatus {
  Active
  Inactive
  Prospect
}

enum SubscriptionStatus {
  Active
  Expired
  Cancelled
  Pending
}

enum FollowUpStatus {
  Pending
  Completed
  Overdue
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MarketingExecutive)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  marketingVisits     MarketingVisit[]
  hostedVisitors      Visitor[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  assignedFollowUps   FollowUp[]

  @@index([role])
  @@index([isActive])
}

model Customer {
  id           String         @id @default(uuid())
  customerCode String         @unique
  name         String
  email        String?
  phone        String?
  city         String?
  status       CustomerStatus @default(Active)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  subscriptions Subscription[]
  visits        MarketingVisit[]
  followUps     FollowUp[]

  @@index([customerCode])
  @@index([status])
}

model Subscription {
  id         String             @id @default(uuid())
  customerId String
  customer   Customer           @relation(fields: [customerId], references: [id])
  planName   String
  startDate  DateTime
  endDate    DateTime
  status     SubscriptionStatus @default(Active)
  notes      String?            @db.NVarChar(Max)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([endDate])
}

model MarketingVisit {
  id              String    @id @default(uuid())
  executiveId     String
  executive       User      @relation(fields: [executiveId], references: [id])
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  checkIn         DateTime  @default(now())
  checkOut        DateTime?
  remarks         String?   @db.NVarChar(Max)
  nextMeetingDate DateTime?
  createdAt       DateTime  @default(now())

  @@index([executiveId])
  @@index([customerId])
  @@index([nextMeetingDate])
  @@index([checkIn])
}

model Visitor {
  id           String    @id @default(uuid())
  visitorName  String
  company      String
  visitorEmail String?
  visitorPhone String
  purpose      String
  inTime       DateTime  @default(now())
  outTime      DateTime?
  hostUserId   String
  host         User      @relation(fields: [hostUserId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hostUserId])
  @@index([inTime])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  module    String
  action    String
  details   String?  @db.NVarChar(Max)
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([timestamp])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model FollowUp {
  id              String         @id @default(uuid())
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id])
  assignedUserId  String
  assignedUser    User           @relation(fields: [assignedUserId], references: [id])
  nextMeetingDate DateTime
  remarks         String?        @db.NVarChar(Max)
  status          FollowUpStatus @default(Pending)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([nextMeetingDate])
}
