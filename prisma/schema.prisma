  status           ServiceStatus    @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerAsset    CustomerAsset?   @relation(fields: [customerAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTeam     ServiceTeam?     @relation(fields: [assignedTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedEngineer ServiceEngineer? @relation(fields: [assignedEngineerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy        User             @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  visits ServiceVisit[]
  review ServiceReview? @relation("RequestReview")
}

model Complaint {
  id                 String    @id @default(uuid())
  title              String
  description        String?   @db.NVarChar(Max)
  categoryId         String
  complaintTypeId    String
  priorityId         String
  statusId           String
  customerId         String
  customerAssetId    String?
  assignedTeamId     String?
  assignedEngineerId String?
  createdById        String
  closedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  category         ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  complaintType    ComplaintType    @relation(fields: [complaintTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  priority         PriorityLevel    @relation(fields: [priorityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           ServiceStatus    @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerAsset    CustomerAsset?   @relation(fields: [customerAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTeam     ServiceTeam?     @relation(fields: [assignedTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedEngineer ServiceEngineer? @relation(fields: [assignedEngineerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy        User             @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  visits ServiceVisit[]
  review ServiceReview? @relation("ComplaintReview")
}

model Defect {
  id                 String    @id @default(uuid())
  title              String
  description        String?   @db.NVarChar(Max)
  categoryId         String
  defectTypeId       String
  priorityId         String
  statusId           String
  customerId         String
  customerAssetId    String?
  assignedTeamId     String?
  assignedEngineerId String?
  createdById        String
  closedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  category         ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  defectType       DefectType       @relation(fields: [defectTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  priority         PriorityLevel    @relation(fields: [priorityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           ServiceStatus    @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerAsset    CustomerAsset?   @relation(fields: [customerAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTeam     ServiceTeam?     @relation(fields: [assignedTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedEngineer ServiceEngineer? @relation(fields: [assignedEngineerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy        User             @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  visits ServiceVisit[]
  review ServiceReview? @relation("DefectReview")
}

model Installation {
  id                 String    @id @default(uuid())
  title              String
  description        String?   @db.NVarChar(Max)
  categoryId         String
  priorityId         String
  statusId           String
  customerId         String
  customerAssetId    String?
  assignedTeamId     String?
  assignedEngineerId String?
  createdById        String
  closedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  category         ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  priority         PriorityLevel    @relation(fields: [priorityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           ServiceStatus    @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerAsset    CustomerAsset?   @relation(fields: [customerAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTeam     ServiceTeam?     @relation(fields: [assignedTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedEngineer ServiceEngineer? @relation(fields: [assignedEngineerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy        User             @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  visits ServiceVisit[]
  review ServiceReview? @relation("InstallationReview")
}

model WarrantyClaim {
  id              String   @id @default(uuid())
  title           String
  description     String?  @db.NVarChar(Max)
  customerId      String
  customerAssetId String
  statusId        String
  claimDate       DateTime @default(now())
  resolution      String?  @db.NVarChar(Max)
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerAsset CustomerAsset @relation(fields: [customerAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status        ServiceStatus @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy     User          @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model AMCContract {
  id              String   @id @default(uuid())
  contractNumber  String   @unique
  customerId      String
  customerAssetId String
  statusId        String
  startDate       DateTime
  endDate         DateTime
  renewalStatus   String? // e.g. "Pending", "Renewed", "Lapsed"
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ── Entitlement plan fields (Feature 4) ──
  planTier                 String?  // e.g. "Basic", "Standard", "Premium"
  preventiveVisitsIncluded Int      @default(0)
  preventiveVisitsUsed     Int      @default(0)
  breakdownCallsUnlimited  Boolean  @default(false)
  breakdownCallsIncluded   Int      @default(0)
  breakdownCallsUsed       Int      @default(0)
  sparesCoverage           String?  // e.g. "Full", "Partial", "None"

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerAsset CustomerAsset @relation(fields: [customerAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status        ServiceStatus @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy     User          @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ServiceVisit {
  id            String    @id @default(uuid())
  title         String
  notes         String?   @db.NVarChar(Max)
  statusId      String
  engineerId    String
  scheduledDate DateTime?
  checkInTime   DateTime?
  checkOutTime  DateTime?
  outcomeNotes  String?   @db.NVarChar(Max)
  completedAt   DateTime?

  // ── Proof-of-work capture (Feature 3) ──
  signatureUrl  String?   @db.NVarChar(Max)

  // Direct customer/asset link (for standalone visits not tied to a source record)
  customerId      String?
  customerAssetId String?

  // Link back to source record using separate nullable FKs
  requestId      String?
  complaintId    String?
  defectId       String?
  installationId String?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  status       ServiceStatus   @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  engineer     ServiceEngineer @relation(fields: [engineerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer     Customer?       @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerAsset CustomerAsset? @relation(fields: [customerAssetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  request      ServiceRequest? @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  complaint    Complaint?      @relation(fields: [complaintId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  defect       Defect?         @relation(fields: [defectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  installation Installation?   @relation(fields: [installationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy    User            @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  review       ServiceReview?  @relation("VisitReview")
  partsUsed    ServicePartUsed[]
  photos       ServiceVisitPhoto[]
  partMovements PartMovement[]
}

model EscalationRule {
  id               String   @id @default(uuid())
  name             String
  categoryId       String
  priorityId       String
  thresholdHours   Int
  triggerCondition String // e.g. "SinceCreation", "StatusUnchanged"
  notifyRoleId     String? // e.g. Role ID to notify
  notifyUserId     String?
  notifyTeamId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  priority   PriorityLevel   @relation(fields: [priorityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notifyUser User?           @relation("EscalationRuleNotifyUser", fields: [notifyUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notifyTeam ServiceTeam?    @relation(fields: [notifyTeamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model RolePermission {
  id        String   @id @default(uuid())
  role      String   // SalesManager | SalesExecutive
  module    String   // Matches the sidebar keys exactly
  visible   Boolean  @default(true)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, module])
}

model ActivityEvent {
  id           String   @id @default(uuid())
  entityType   String
  entityId     String
  rootEntityId String?
  type         String
  fromStatus   String?
  toStatus     String?
  roundNumber  Int?
  actorId      String?
  metadata     String?  @db.NVarChar(Max)
  createdAt    DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([rootEntityId, createdAt])
  @@index([type, createdAt])
}

model ServiceReview {
  id                 String    @id @default(uuid())
  rating             Int?
  comment            String?   @db.NVarChar(Max)
  status             String    @default("Pending") // Pending | Submitted
  isEscalation       Boolean   @default(false)
  escalationResolved Boolean   @default(false)
  token              String    @unique @default(uuid()) // For public submission link
  
  customerId         String
  engineerId         String
  
  // Nullable FKs to source records
  serviceRequestId   String?   @unique
  complaintId        String?   @unique
  defectId           String?   @unique
  installationId     String?   @unique
  serviceVisitId     String?   @unique
  
  requestedAt        DateTime  @default(now())
  submittedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  customer           Customer        @relation("CustomerReviews", fields: [customerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  engineer           ServiceEngineer @relation("EngineerReviews", fields: [engineerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  serviceRequest     ServiceRequest? @relation("RequestReview", fields: [serviceRequestId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  complaint          Complaint?      @relation("ComplaintReview", fields: [complaintId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  defect             Defect?         @relation("DefectReview", fields: [defectId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  installation       Installation?   @relation("InstallationReview", fields: [installationId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  serviceVisit       ServiceVisit?   @relation("VisitReview", fields: [serviceVisitId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([customerId])
  @@index([engineerId])
}

// ==========================================
// PROJECT MODEL (Feature 1)
// Groups multiple CustomerAssets under a project
// ==========================================

model Project {
  id          String    @id @default(uuid())
  projectCode String    @unique
  name        String
  customerId  String
  dealId      String?
  status      String    @default("Active") // Active | Completed | On Hold | Cancelled
  startDate   DateTime?
  endDate     DateTime?
  notes       String?   @db.NVarChar(Max)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deal       Deal?            @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy  User             @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assets     CustomerAsset[]  @relation("ProjectAssets")

  @@index([customerId])
  @@index([dealId])
  @@index([status])
}

// ==========================================
// SPARE PARTS MASTER DATA (Feature 2)
// ==========================================

model SparePart {
  id           String   @id @default(uuid())
  partCode     String   @unique
  partName     String
  category     String?
  unit         String?  // e.g. "pcs", "set", "meter"
  unitCost     Float    @default(0)
  currency     String   @default("INR")
  currentStock Int      @default(0)  // maintained via PartMovement
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  servicePartsUsed ServicePartUsed[]
  partMovements    PartMovement[]

  @@index([partCode])
  @@index([category])
}

// ==========================================
// SERVICE PARTS USED (Feature 2)
// Tracks spare parts consumed during a service visit
// ==========================================

model ServicePartUsed {
  id             String   @id @default(uuid())
  serviceVisitId String
  sparePartId    String?
  partName       String   // snapshot of part name at time of use
  quantity       Int      @default(1)
  unitCost       Float    @default(0)
  totalCost      Float    @default(0)
  createdAt      DateTime @default(now())

  serviceVisit ServiceVisit @relation(fields: [serviceVisitId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sparePart    SparePart?   @relation(fields: [sparePartId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([serviceVisitId])
  @@index([sparePartId])
}

// ==========================================
// SERVICE VISIT PHOTOS (Feature 3)
// Stores site photos captured during visit completion
// ==========================================

model ServiceVisitPhoto {
  id             String   @id @default(uuid())
  serviceVisitId String
  photoUrl       String   @db.NVarChar(Max)
  caption        String?
  createdAt      DateTime @default(now())

  serviceVisit ServiceVisit @relation(fields: [serviceVisitId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([serviceVisitId])
}

// ==========================================
// PART MOVEMENT LEDGER (Spare Parts Inventory v1)
// Append-only ledger — never edit past rows, only add new ones.
// ==========================================

model PartMovement {
  id              String   @id @default(uuid())
  sparePartId     String
  type            String   // "Issued" | "Used" | "Returned" | "Damaged"
  quantity        Int
  engineerId      String?
  serviceVisitId  String?
  customerAssetId String?
  notes           String?
  createdById     String
  createdAt       DateTime @default(now())

  sparePart     SparePart        @relation(fields: [sparePartId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  engineer      ServiceEngineer? @relation(fields: [engineerId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  serviceVisit  ServiceVisit?    @relation(fields: [serviceVisitId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  customerAsset CustomerAsset?   @relation(fields: [customerAssetId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  createdBy     User             @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([sparePartId])
  @@index([engineerId])
  @@index([serviceVisitId])
  @@index([type])
}
