generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "library"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                      @id @default(uuid())
  email                       String                      @unique
  name                        String
  passwordHash                String
  role                        String                      @default("SalesExecutive")
  userType                    String                      @default("internal")
  phone                       String?
  profilePhoto                String?                     @db.NVarChar(Max)
  isActive                    Boolean                     @default(true)
  isFirstLogin                Boolean                     @default(true)
  otpCode                     String?
  otpExpiry                   DateTime?
  otpAttempts                 Int                         @default(0)
  resetToken                  String?                     @db.NVarChar(Max)
  resetTokenExpiry            DateTime?
  loginAttempts               Int                         @default(0)
  lockedUntil                 DateTime?
  lastLoginAt                 DateTime?
  invitedBy                   String?
  invitedAt                   DateTime?
  rememberMe                  Boolean                     @default(false)
  lastActivityAt              DateTime?
  activationToken             String?                     @db.NVarChar(Max)
  activationTokenExpiry       DateTime?
  passwordSetAt               DateTime?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  companyId                   String?
  deletedAt                   DateTime?
  deletedById                 String?
  theme                       String                      @default("ocean")
  themeMode                   String                      @default("light")
  preferredCurrency           String                      @default("INR")
  department                  String?
  activityAttendees           ActivityAttendee[]
  requestedApprovals          ApprovalHistory[]           @relation("RequestedApprovals")
  resolvedApprovals           ApprovalHistory[]           @relation("ResolvedApprovals")
  approvalRequests            ApprovalRequest[]           @relation("ApprovalRequestRequestedBy")
  approvalResolvedBy          ApprovalRequest[]           @relation("ApprovalRequestResolvedBy")
  auditLogs                   AuditLog[]
  callLogs                    CallLog[]
  communicationLogs           CommunicationLog[]
  Contact                     Contact[]
  documentDeletedBy           CRMDocument[]               @relation("DocumentDeletedBy")
  documents                   CRMDocument[]               @relation("UploadedDocuments")
  assignedCustomers           Customer[]                  @relation("AssignedCustomers")
  onboardedCustomers          Customer[]                  @relation("OnboardedCustomers")
  customerVisits              CustomerVisit[]
  assignedDeals               Deal[]
  approvedDiscounts           Deal[]                      @relation("ApprovedDiscounts")
  dealStageHistories          DealStageHistory[]
  assignedFollowUps           FollowUp[]                  @relation("AssignedFollowUps")
  completedFollowUps          FollowUp[]                  @relation("CompletedFollowUps")
  forecastEntries             ForecastEntry[]
  keyAccountsManaged          KeyAccount[]                @relation("ManagedKeyAccounts")
  leads                       Lead[]
  leadOwnerHistoryChangedBy   LeadOwnerHistory[]          @relation("OwnerHistoryChangedBy")
  leadOwnerHistoryFrom        LeadOwnerHistory[]          @relation("OwnerHistoryFrom")
  leadOwnerHistoryTo          LeadOwnerHistory[]          @relation("OwnerHistoryTo")
  lostDealAnalysesRecorded    LostDealAnalysis[]          @relation("RecordedLostDealAnalyses")
  approvedVisits              MarketingVisit[]            @relation("ApprovedVisits")
  marketingVisits             MarketingVisit[]            @relation("ExecutiveVisits")
  approvedNegotiations        Negotiation[]               @relation("ApprovedNegotiations")
  visitStatusChanges          CustomerVisitStatusLog[]
  assignedVisits              CustomerVisit[]             @relation("AssignedVisits")
  visitHosts                  VisitHost[]                 @relation("VisitHosts")
  assignedNegotiations        Negotiation[]               @relation("AssignedNegotiations")
  negotiationDeletedBy        Negotiation[]               @relation("NegotiationDeletedBy")
  negotiationRevisions        NegotiationRevision[]       @relation("NegotiationRevisions")
  approvedNegotiationRevisions NegotiationRevision[]      @relation("ApprovedNegotiationRevisions")
  createdNotes                Note[]                      @relation("CreatedNotes")
  notifications               Notification[]
  notificationPrefs           NotificationPreference?
  passwordResetTokens         PasswordResetToken[]
  proposalVersions            ProposalVersion[]
  approvedPurchaseOrders      PurchaseOrder[]             @relation("ApprovedPurchaseOrders")
  assignedPurchaseOrders      PurchaseOrder[]             @relation("AssignedPurchaseOrders")
  purchaseOrderDeletedBy      PurchaseOrder[]             @relation("PurchaseOrderDeletedBy")
  assignedQuotations          Quotation[]                 @relation("AssignedQuotations")
  createdQuotations           Quotation[]                 @relation("CreatedQuotations")
  quotationApprover           QuotationApproval[]         @relation("QuotationApprover")
  requestedQuotationApprovals QuotationApproval[]         @relation("RequestedQuotationApprovals")
  quotationRevisionAuthors    QuotationApproval[]         @relation("QuotationRevisionAuthors")
  createdRevisionSnapshots    QuotationRevisionSnapshot[] @relation("CreatedRevisionSnapshots")
  quotationDocuments         QuotationDocument[]         @relation("QuotationDocumentsGenerated")
  changedQuotationStatuses    QuotationStatusHistory[]    @relation("ChangedQuotationStatus")
  exportedReports             ReportExportLog[]           @relation("ExportedReports")
  createdReportSchedules      ReportSchedule[]            @relation("CreatedReportSchedules")
  rfqs                        RFQ[]                       @relation("AssignedRFQs")
  costingRFQs                 RFQ[]                       @relation("CostingOwnerRFQs")
  revisedRFQs                 RFQ[]                       @relation("RevisedRFQs")
  submittedCostingSheets      RFQCostingSheet[]           @relation("SubmittedCostingSheets")
  changedRFQStatuses          RFQStatusHistory[]          @relation("ChangedRFQStatus")
  salesTargets                SalesTarget[]               @relation("AssignedSalesTargets")
  approvedSamples             SampleRequest[]             @relation("ApprovedSamples")
  assignedSamples             SampleRequest[]             @relation("AssignedSamples")
  sampleDeletedBy             SampleRequest[]             @relation("SampleDeletedBy")
  rejectedSamples             SampleRequest[]             @relation("RejectedSamples")
  assignedTickets             SupportTicket[]
  tasksAssignedBy             Task[]                      @relation("TaskAssignedBy")
  Task                        Task[]
  taskComments                TaskComment[]
  territoriesOwned            Territory[]                 @relation("AssignedTerritories")
  company                     Company?                    @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hostedVisitors              Visitor[]
  ciCreated                   CompetitorInvolvement[]     @relation("CompetitorInvolvementCreator")
  ciUpdated                   CompetitorInvolvement[]     @relation("CompetitorInvolvementUpdater")
  ciDiscountApproved          CompetitorInvolvement[]     @relation("CompetitorInvolvementDiscountApprover")
  managedTeams                ServiceTeam[]               @relation("TeamManager")
  serviceEngineers            ServiceEngineer[]           @relation("UserEngineer")
  technicalNotes              OpportunityTechnicalNote[]  @relation("EngineerTechnicalNotes")

  serviceRequests           ServiceRequest[]
  complaints                Complaint[]
  defects                   Defect[]
  installations             Installation[]
  warrantyClaims            WarrantyClaim[]
  amcContracts              AMCContract[]
  serviceVisits             ServiceVisit[]
  escalationRulesNotifyUser EscalationRule[] @relation("EscalationRuleNotifyUser")
  projectsCreated           Project[]         @relation("ProjectCreatedBy")
  partMovementsCreated      PartMovement[]

  @@index([role])
  @@index([isActive])
  @@index([userType])
  @@index([companyId])
}

model Customer {
  id               String    @id @default(uuid())
  customerCode     String    @unique
  name             String
  email            String?   @unique
  phone            String?
  city             String?
  status           String    @default("Prospect")
  assignedUserId   String?
  onboardingStatus String    @default("Pending")
  onboardedAt      DateTime?
  onboardedById    String?

  serviceRequests        ServiceRequest[]
  complaints             Complaint[]
  defects                Defect[]
  installations          Installation[]
  warrantyClaims         WarrantyClaim[]
  amcContracts           AMCContract[]
  serviceVisits           ServiceVisit[]
  convertedFromLead      String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  companyId              String?
  deletedAt              DateTime?
  deletedById            String?
  leadSource             String?
  accountType            String                  @default("Prospect")
  billingAddress         String?                 @db.NVarChar(Max)
  creditLimit            Float                   @default(0)
  creditTermsDays        Int                     @default(30)
  gstNumber              String?
  industryType           String?
  isKeyAccountV2         Boolean                 @default(false)
  lastActivityDate       DateTime?
  shippingAddress        String?                 @db.NVarChar(Max)
  creditHistories        AccountCreditHistory[]
  accountStatusHistories AccountStatusHistory[]
  callLogs               CallLog[]
  communicationLogs      CommunicationLog[]
  contacts               Contact[]
  documents              CRMDocument[]
  assignedUser           User?                   @relation("AssignedCustomers", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company                Company?                @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  onboardedBy            User?                   @relation("OnboardedCustomers", fields: [onboardedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customerVisits         CustomerVisit[]
  deals                  Deal[]
  followUps              FollowUp[]
  invoices               Invoice[]
  keyAccounts            KeyAccount[]
  marketingVisits        MarketingVisit[]
  negotiations           Negotiation[]
  plantLocations         PlantLocation[]
  proposals              Proposal[]
  purchaseOrders         PurchaseOrder[]
  quotations             Quotation[]
  rfqs                   RFQ[]
  samples                SampleRequest[]
  subscriptions          Subscription[]
  supportTickets         SupportTicket[]
  territoryAccounts      TerritoryAccount[]
  competitorInvolvements CompetitorInvolvement[] @relation("CompetitorInvolvementCustomer")
  assets                 CustomerAsset[]         @relation("CustomerAssets")
  serviceReviews         ServiceReview[]         @relation("CustomerReviews")
  projects               Project[]

  @@index([customerCode])
  @@index([status])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([gstNumber])
  @@index([isKeyAccountV2])
}

model Subscription {
  id                 String    @id @default(uuid())
  customerId         String
  planName           String
  startDate          DateTime
  endDate            DateTime
  status             String    @default("Active")
  notes              String?   @db.NVarChar(Max)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  renewalAlertSent30 Boolean   @default(false)
  renewalAlertSent7  Boolean   @default(false)
  companyId          String?
  deletedAt          DateTime?
  deletedById        String?
  company            Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer           Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([endDate])
  @@index([companyId])
}

model CustomerVisit {
  id                        String                   @id @default(uuid())
  customerId                String
  hostedBy                  String
  visitType                 String                   @default("field_visit") // field_visit or office_visit
  purpose                   String
  checkInTime               DateTime?
  checkOutTime              DateTime?
  meetingSummary            String?                  @db.NVarChar(Max)
  outcome                   String?
  customerDecision          String?
  rejectionReason           String?                  @db.NVarChar(Max)
  nextMeetingDate           DateTime?
  nextMeetingNotes          String?                  @db.NVarChar(Max)
  status                    String                   @default("PLANNED")
  priority                  String                   @default("Normal")
  meetingType               String?
  source                    String?
  agenda                    String?                  @db.NVarChar(Max)
  department                String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  companyId                 String?
  deletedAt                 DateTime?
  deletedById               String?
  gpsAnomaly                Boolean?
  gpsLat                    Float?
  gpsLng                    Float?
  linkedOpportunityId       String?
  nextAction                String?
  plannedDate               DateTime?
  plannedTime               String?
  plantLocationId           String?
  visitSummary              String?                  @db.NVarChar(Max)
  checkOutGpsAnomaly        Boolean?
  checkOutGpsLocation       String?
  customerUnavailableReason String?                  @db.NVarChar(Max)
  durationMinutes           Int?
  outcomeType               String?
  parentVisitId             String?
  rescheduleCount           Int                      @default(0)
  rescheduleReason          String?                  @db.NVarChar(Max)
  autoCheckedOut            Boolean                  @default(false)
  autoCheckoutReason        String?                  @db.NVarChar(Max)
  longVisit                 Boolean                  @default(false)
  longVisitJustification    String?                  @db.NVarChar(Max)
  visited4HrWarningSent     Boolean                  @default(false)
  visited8HrAlertSent       Boolean                  @default(false)
  // Office visit specific fields
  visitorNames              String?                  @db.NVarChar(Max)
  meetingRoom               String?
  signInTime                DateTime?
  signOutTime               DateTime?
  documentsExchanged        String?                  @db.NVarChar(Max)
  // Field visit specific fields
  gpsDistanceFromSite       Float?
  travelMode                String?
  distanceTraveledKm        Float?
  expenseAmount             Float?
  locationVerified          Boolean                  @default(true)
  manualLocationNote        String?                  @db.NVarChar(Max)
  // Unified fields
  outcomeNotes              String?                  @db.NVarChar(Max)
  nextActionDate            DateTime?
  nextActionNotes           String?                  @db.NVarChar(Max)
  entityType                String?
  entityId                  String?
  assignedUserId            String?
  cancelledReason           String?                  @db.NVarChar(Max)
  checkInBy                 String?
  company                   Company?                 @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer                  Customer                 @relation(fields: [customerId], references: [id], onUpdate: NoAction)
  host                      User                     @relation(fields: [hostedBy], references: [id], onUpdate: NoAction)
  assignedUser              User?                    @relation("AssignedVisits", fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  linkedOpportunity         Deal?                    @relation("VisitLinkedOpportunity", fields: [linkedOpportunityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentVisit               CustomerVisit?           @relation("VisitFollowUps", fields: [parentVisitId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childVisits               CustomerVisit[]          @relation("VisitFollowUps")
  plantLocation             PlantLocation?           @relation(fields: [plantLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visitAttendees            CustomerVisitAttendee[]
  visitHosts                VisitHost[]
  visitors                  VisitVisitor[]
  statusLogs                CustomerVisitStatusLog[]

  @@index([customerId])
  @@index([hostedBy])
  @@index([status])
  @@index([companyId])
  @@index([plantLocationId])
  @@index([linkedOpportunityId])
  @@index([parentVisitId])
  @@index([entityType, entityId])
  @@index([assignedUserId])
  @@index([visitType])
}

model CustomerVisitAttendee {
  id        String        @id @default(uuid())
  visitId   String
  contactId String
  createdAt DateTime      @default(now())
  contact   Contact       @relation(fields: [contactId], references: [id], onUpdate: NoAction)
  visit     CustomerVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([contactId])
}

model VisitHost {
  id        String        @id @default(uuid())
  visitId   String
  userId    String
  createdAt DateTime      @default(now())
  visit     CustomerVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user      User          @relation("VisitHosts", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([visitId])
  @@index([userId])
}

model VisitVisitor {
  id          String        @id @default(uuid())
  visitId     String
  name        String
  designation String?
  createdAt   DateTime      @default(now())
  visit       CustomerVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model CustomerVisitStatusLog {
  id         String   @id @default(uuid())
  visitId    String
  fromStatus String
  toStatus   String
  changedBy  String
  changedAt  DateTime
  reason     String?  @db.NVarChar(Max)
  companyId  String?

  visit         CustomerVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  changedByUser User          @relation(fields: [changedBy], references: [id], onUpdate: NoAction)

  @@index([visitId])
  @@index([changedBy])
  @@index([toStatus])
  @@index([companyId])
}

model MarketingVisit {
  id                 String          @id @default(uuid())
  executiveId        String
  customerId         String?
  leadId             String?
  checkIn            DateTime?
  checkOut           DateTime?
  checkInLat         Float?
  checkInLng         Float?
  checkOutLat        Float?
  checkOutLng        Float?
  checkInPhoto       String?
  remarks            String?         @db.NVarChar(Max)
  nextMeetingDate    DateTime?
  createdAt          DateTime        @default(now())
  purpose            String?
  meetingDescription String?         @db.NVarChar(Max)
  outcome            String?
  customerDecision   String?
  rejectionReason    String?         @db.NVarChar(Max)
  nextMeetingNotes   String?         @db.NVarChar(Max)
  status             String          @default("REQUESTED")
  approvedByUserId   String?
  approvedAt         DateTime?
  updatedAt          DateTime?       @updatedAt
  companyId          String?
  deletedAt          DateTime?
  deletedById        String?
  approvedByUser     User?           @relation("ApprovedVisits", fields: [approvedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company            Company?        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer           Customer?       @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  executive          User            @relation("ExecutiveVisits", fields: [executiveId], references: [id], onUpdate: NoAction)
  lead               Lead?           @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  attendees          VisitAttendee[]

  @@index([executiveId])
  @@index([customerId])
  @@index([leadId])
  @@index([nextMeetingDate])
  @@index([status])
  @@index([companyId])
}

model Visitor {
  id           String    @id @default(uuid())
  visitorName  String
  company      String
  visitorEmail String?
  visitorPhone String
  purpose      String
  inTime       DateTime  @default(now())
  outTime      DateTime?
  hostUserId   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  host         User      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)

  @@index([hostUserId])
  @@index([inTime])
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  module        String
  action        String
  details       String?  @db.NVarChar(Max)
  resourceId    String?
  previousState String?  @db.NVarChar(Max)
  newState      String?  @db.NVarChar(Max)
  ipAddress     String?
  userAgent     String?  @db.NVarChar(Max)
  severity      String   @default("INFO")
  companyId     String?
  timestamp     DateTime @default(now())
  company       Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user          User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([module])
  @@index([timestamp])
  @@index([severity])
  @@index([resourceId])
  @@index([companyId])
  @@index([module, resourceId, timestamp])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FollowUp {
  id                String             @id @default(uuid())
  customerId        String?
  leadId            String?
  dealId            String?
  assignedUserId    String
  nextMeetingDate   DateTime
  remarks           String?            @db.NVarChar(Max)
  status            String             @default("Pending")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  visitId           String?
  visitType         String?
  completedAt       DateTime?
  notes             String?            @db.NVarChar(Max)
  dueDate           DateTime?
  reminderAt        DateTime?
  completedById     String?
  sourceType        String?
  sourceId          String?
  completionNotes   String?            @db.NVarChar(Max)
  priority          String             @default("Medium")
  escalationLevel   Int                @default(0)
  autoCreated       Boolean            @default(false)
  companyId         String?
  deletedAt         DateTime?
  deletedById       String?
  type              String?
  nextFollowupId    String?
  entityType        String?
  entityId          String?
  stageAtCreation   String?
  communicationLogs CommunicationLog[]
  assignedUser      User               @relation("AssignedFollowUps", fields: [assignedUserId], references: [id], onUpdate: NoAction)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  completedBy       User?              @relation("CompletedFollowUps", fields: [completedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lead              Lead?              @relation(fields: [leadId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deal              Deal?              @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nextFollowUp      FollowUp?          @relation("ChainedFollowUp", fields: [nextFollowupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prevFollowUps     FollowUp[]         @relation("ChainedFollowUp")

  @@index([customerId])
  @@index([leadId])
  @@index([dealId])
  @@index([assignedUserId])
  @@index([status])
  @@index([nextMeetingDate])
  @@index([completedById])
  @@index([companyId])
  @@index([type])
  @@index([entityType, entityId])
  @@index([assignedUserId, status, nextMeetingDate])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.NVarChar(Max)
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead, createdAt])
}

model NotificationPreference {
  id                  Int     @id @default(autoincrement())
  userId              String  @unique
  emailFollowUp       Boolean @default(true)
  emailVisitorCheckIn Boolean @default(false)
  inAppVisitUpdate    Boolean @default(true)
  notifyOnDealStatus  Boolean @default(true)
  notifyOnCallLog     Boolean @default(true)
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deal {
  id                     String                       @id @default(uuid())
  dealName               String
  customerId             String
  dealValue              Float
  expectedCloseDate      DateTime
  assignedUserId         String?
  notes                  String?                      @db.NVarChar(Max)
  status                 String                       @default("Qualified")
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  discountPercent        Float                        @default(0.0)
  discountStatus         String                       @default("None")
  isLocked               Boolean                      @default(false)
  discountNotes          String?                      @db.NVarChar(Max)
  discountApprovedById   String?
  lostReason             String?                      @db.NVarChar(Max)
  approvalRemarks        String?                      @db.NVarChar(Max)
  companyId              String?
  deletedAt              DateTime?
  deletedById            String?
  forecastEntryDate      DateTime?
  renewalDate            DateTime?
  isOverdue              Boolean                      @default(false)
  lostReasonRefId        String?
  opportunityCode        String?
  probabilityPercent     Int                          @default(20)
  stageEnteredAt         DateTime? // Timestamp when current stage was entered — for per-stage overdue computation
  rejectedReason         String?                      @db.NVarChar(Max) // Reason for rejection (distinct from lostReason)
  approvalHistory        ApprovalHistory[]
  linkedVisits           CustomerVisit[]              @relation("VisitLinkedOpportunity")
  assignedUser           User?                        @relation(fields: [assignedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company                Company?                     @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer               Customer                     @relation(fields: [customerId], references: [id], onUpdate: NoAction)
  discountApprovedBy     User?                        @relation("ApprovedDiscounts", fields: [discountApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lostReasonRef          LossReason?                  @relation("DealLossReason", fields: [lostReasonRefId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stageHistories         DealStageHistory[]
  lostDealAnalyses       LostDealAnalysis[]
  negotiations           Negotiation[]
  opportunityContacts    OpportunityContact[]
  opportunityDetail      OpportunityDetail?
  meetingLogs            MeetingLog[]                 @relation("DealMeetingLogs")
  requirementItems       OpportunityRequirementItem[] @relation("DealRequirementItems")
  proposals              Proposal[]
  purchaseOrders         PurchaseOrder[]
  quotations             Quotation[]
  rfqs                   RFQ[]                        @relation("OpportunityRFQs")
  tasks                  Task[]
  competitorInvolvements CompetitorInvolvement[]      @relation("CompetitorInvolvementDeal")
  customerAssets         CustomerAsset[]               @relation("CustomerAssetDeal")
  followUps              FollowUp[]
  projects               Project[]

  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([companyId])
  @@index([opportunityCode])
  @@index([isOverdue])
  @@index([status, assignedUserId, isOverdue, expectedCloseDate])
}

model OpportunityDetail {
  id                      String    @id @default(uuid())
  dealId                  String    @unique
  currentChallenges       String?   @db.NVarChar(Max)
  painPoints              String?   @db.NVarChar(Max)
  painPointsList          String?   @db.NVarChar(Max)
  requiredFeatures        String?   @db.NVarChar(Max)
  modulesRequired         String?   @db.NVarChar(Max)
  deploymentType          String?
  integrationsRequired    String?   @db.NVarChar(Max)
  userCountSales          Int?
  userCountManagers       Int?
  userCountAdmins         Int?
  budgetRange             String?
  timeline                String?
  procurementProcess      String?
  decisionMaker           String?
  influencer              String?
  budgetOwner             String?
  expectedGoLive          DateTime?
  currentVendor           String?
  competitorsEvaluated    String?   @db.NVarChar(Max)


  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  apiThirdPartyReqs       String?   @db.NVarChar(Max)
  approvalProcess         String?   @db.NVarChar(Max)
  billingCycle            String?
  businessGoals           String?   @db.NVarChar(Max)
  businessNeed            String?   @db.NVarChar(Max)
  buyingAuthorityNotes    String?   @db.NVarChar(Max)
  companyName             String?
  contactPerson           String?
  customizationNeeded     String?   @db.NVarChar(Max)
  dataMigrationRequired   String?
  email                   String?
  employeeCount           Int?
  existingSoftwareStack   String?   @db.NVarChar(Max)
  expectedBudget          Float?
  expectedOutcome         String?   @db.NVarChar(Max)
  finalDiscussedBudget    Float?
  followUpSummary         String?   @db.NVarChar(Max)
  industry                String?
  internalSalesNotes      String?   @db.NVarChar(Max)
  itTeamNotes             String?   @db.NVarChar(Max)
  licenseCount            Int?
  managementNotes         String?   @db.NVarChar(Max)
  nextSteps               String?   @db.NVarChar(Max)
  numberOfUsers           Int?
  objections              String?   @db.NVarChar(Max)
  phone                   String?
  presalesNotes           String?   @db.NVarChar(Max)
  probability             Int?
  reportingRequirements   String?   @db.NVarChar(Max)
  requiredDepartments     String?   @db.NVarChar(Max)
  risksBlockers           String?   @db.NVarChar(Max)
  securityCompliance      String?   @db.NVarChar(Max)
  successCriteria         String?   @db.NVarChar(Max)
  technicalConstraints    String?   @db.NVarChar(Max)
  urgencyPriority         String?
  userRolesPermissions    String?   @db.NVarChar(Max)
  requirementCompletedAt  DateTime?
  sampleRequested         Boolean   @default(false)
  sampleApproved          Boolean   @default(false)
  sampleApprovedDate      DateTime?
  sampleRejectedReason    String?   @db.NVarChar(Max)
  // V2 fields
  requiresSamples         String? // "yes" | "no" | null — set during Qualified stage
  sampleStatus            String? // "pending" | "approved" | "rejected" | null — tracks sample management branch
  techDiscussionDate      DateTime? // V2 Part B: technical discussion date
  techDiscussionAttendees String?   @db.NVarChar(Max) // V2 Part B: attendees
  techDiscussionQuestions String?   @db.NVarChar(Max) // V2 Part B: questions raised
  techDiscussionConfirmed Boolean   @default(false) // V2 Part B: exit gate checkbox (deprecated — now handled by TechnicalDiscussion stage gate)
  // V5 Manufacturing Pipeline fields
  leadVerified            Boolean   @default(false) // Qualified stage — replaces businessNeed bool (avoids key collision with RG's businessNeed textarea)
  tdDiscussionDate        DateTime? // TechnicalDiscussion stage header date
  tdAttendees             String?   @db.NVarChar(Max) // TechnicalDiscussion stage attendees
  tdEngineerId            String? // TechnicalDiscussion stage — assigned engineer user ID
  additionalNotes         String?   @db.NVarChar(Max) // RG stage — consolidates narrative notes (objections, risks, next steps, etc.)
  // Commercial Information — extra fields used in RG form
  paymentTerms            String?   @db.NVarChar(Max)
  competitorInfo          String?   @db.NVarChar(Max)
  commercialRisks         String?   @db.NVarChar(Max)
  discountRequested       Float?
  proposalValue           Float?
  negotiationNotes        String?   @db.NVarChar(Max)
  deal                    Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ─── Meeting Log (replaces flat meeting fields) ─────────────────────────────────
model MeetingLog {
  id              String    @id @default(cuid())
  dealId          String
  deal            Deal      @relation("DealMeetingLogs", fields: [dealId], references: [id], onDelete: Cascade)
  attemptNumber   Int       @default(1)
  meetingDate     DateTime?
  meetingType     String?
  meetingMode     String?
  participants    String?   @db.NVarChar(Max)
  agenda          String?   @db.NVarChar(Max)
  conductedAt     DateTime?
  outcome         String?   // "Accepted", "Rejected", "Follow-up needed"
  notes           String?   @db.NVarChar(Max) // Demo feedback or meeting outcome notes
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([dealId])
  @@index([meetingDate])
}

// ─── Manufacturing Pipeline — Product Requirement Items ─────────────────────
// One row per product per deal, capturing manufacturing-specific requirement data.
// Created during Requirement Gathering stage; referenced in Technical Discussion.
model OpportunityRequirementItem {
  id                String                    @id @default(cuid())
  dealId            String
  deal              Deal                      @relation("DealRequirementItems", fields: [dealId], references: [id], onDelete: Cascade)
  productName       String
  estimatedQuantity Int
  targetPriceMin    Decimal?                  @db.Decimal(12, 2)
  targetPriceMax    Decimal?                  @db.Decimal(12, 2)
  material          String?
  requiredDelivery  DateTime?
  specNotes         String?                   @db.NVarChar(Max)
  attachmentUrl     String?                   @db.NVarChar(Max)
  displayOrder      Int                       @default(0)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  technicalNote     OpportunityTechnicalNote?
  rfqLineItems      RFQLineItem[]

  @@index([dealId])
}

// ─── Technical Discussion — Per-product feasibility note ────────────────────
// One row per OpportunityRequirementItem, capturing engineer feasibility review.
// Created during Technical Discussion stage; referenced in RFQ auto-creation.
model OpportunityTechnicalNote {
  id                String                     @id @default(cuid())
  requirementItemId String                     @unique
  requirementItem   OpportunityRequirementItem @relation(fields: [requirementItemId], references: [id], onDelete: Cascade)
  feasibility       String // Feasible | FeasibleWithChanges | NotFeasible
  confirmedSpec     String?                    @db.NVarChar(Max)
  toolingRequired   String?                    @db.NVarChar(Max)
  engineerId        String
  engineer          User                       @relation("EngineerTechnicalNotes", fields: [engineerId], references: [id], onUpdate: NoAction)
  reviewedAt        DateTime                   @default(now())

  @@index([requirementItemId])
  @@index([engineerId])
}

