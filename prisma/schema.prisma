  company                  Company?                    @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contact                  Contact?                    @relation(fields: [contactId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy                User                        @relation("CreatedQuotations", fields: [createdById], references: [id], onUpdate: NoAction)
  customer                 Customer                    @relation(fields: [customerId], references: [id], onUpdate: NoAction)
  deal                     Deal?                       @relation(fields: [dealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  negotiation              Negotiation?                @relation("NegotiationQuotationRevisions", fields: [negotiationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentQuotation          Quotation?                  @relation("QuotationRevisions", fields: [parentQuotationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childRevisions           Quotation[]                 @relation("QuotationRevisions")
  rfq                      RFQ?                        @relation(fields: [rfqId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quotationApprovals       QuotationApproval[]
  items                    QuotationItem[]
  revisionSnapshots        QuotationRevisionSnapshot[]
  quotationStatusHistories QuotationStatusHistory[]
  competitorInvolvements   CompetitorInvolvement[]     @relation("CompetitorInvolvementQuotation")
  documents                QuotationDocument[]

