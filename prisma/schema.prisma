  @@index([status])
  @@index([companyId])
  @@index([rfqId])
  @@index([validUntil])
  @@index([revisionNumber])
  @@index([status, validUntil])
  @@index([negotiationId])
  @@index([parentQuotationId])
  @@index([currentRound])
}

