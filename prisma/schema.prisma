// ─── LOCAL DEVELOPMENT SCHEMA (MySQL) ────────────────────────────────────────
// Used when DB_PROVIDER=mysql (or NODE_ENV=development)
// Connection string format: mysql://user:password@localhost:3306/database

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Admin
  MarketingLead
  MarketingExecutive
  Customer
}

enum CustomerStatus {
  Active
  Inactive
  Prospect
}

enum SubscriptionStatus {
  Active
  Expired
  Cancelled
  Pending
}

enum FollowUpStatus {
  Pending
  Completed
  Overdue
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MarketingExecutive)
  isActive           Boolean   @default(true)
  isFirstLogin       Boolean   @default(true)
  otpCode            String?
  otpExpiry          DateTime?
  otpAttempts        Int       @default(0)
  resetToken         String?
  resetTokenExpiry   DateTime?
  loginAttempts      Int       @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  invitedBy          String?
  invitedAt          DateTime?
  passwordSetAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  marketingVisits     MarketingVisit[]
  hostedVisitors      Visitor[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  assignedFollowUps   FollowUp[]
  assignedCustomers   Customer[] @relation("AssignedCustomers")

  @@index([role])
  @@index([isActive])
}

model Customer {
  id           String         @id @default(uuid())
  customerCode String         @unique
  name         String
  email        String?
  phone        String?
  city           String?
  status         CustomerStatus @default(Active)
  assignedUserId String?
  assignedUser   User?          @relation("AssignedCustomers", fields: [assignedUserId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  subscriptions Subscription[]
  visits        MarketingVisit[]
  followUps     FollowUp[]

  @@index([customerCode])
  @@index([status])
  @@index([assignedUserId])
}

model Subscription {
  id         String             @id @default(uuid())
  customerId String
  customer   Customer           @relation(fields: [customerId], references: [id])
  planName   String
  startDate  DateTime
  endDate    DateTime
  status     SubscriptionStatus @default(Active)
  notes      String?            @db.Text
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([endDate])
}

model MarketingVisit {
  id              String    @id @default(uuid())
  executiveId     String
  executive       User      @relation(fields: [executiveId], references: [id])
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  checkIn         DateTime  @default(now())
  checkOut        DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkOutLat     Float?
  checkOutLng     Float?
  checkInPhoto    String?
  remarks         String?   @db.Text
  nextMeetingDate DateTime?
  createdAt       DateTime  @default(now())

  @@index([executiveId])
  @@index([customerId])
  @@index([nextMeetingDate])
  @@index([checkIn])
}

model Visitor {
  id           String    @id @default(uuid())
  visitorName  String
  company      String
  visitorEmail String?
  visitorPhone String
  purpose      String
  inTime       DateTime  @default(now())
  outTime      DateTime?
  hostUserId   String
  host         User      @relation(fields: [hostUserId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hostUserId])
  @@index([inTime])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  module    String
  action    String
  details   String?  @db.Text
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([timestamp])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model FollowUp {
  id              String         @id @default(uuid())
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id])
  assignedUserId  String
  assignedUser    User           @relation(fields: [assignedUserId], references: [id])
  nextMeetingDate DateTime
  remarks         String?        @db.Text
  status          FollowUpStatus @default(Pending)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([nextMeetingDate])
}
