model Quotation {
  id                       String                      @id @default(uuid())
  quotationCode            String                      @unique
  rfqId                    String?
  customerId               String
  contactId                String?
  dealId                   String?
  status                   String                      @default("Draft")
  validUntil               DateTime
  totalAmount              Float                       @default(0)
  discountPercent          Float                       @default(0)
  finalAmount              Float                       @default(0)
  overallMarginPercent     Decimal?                    @db.Decimal(8, 2)
